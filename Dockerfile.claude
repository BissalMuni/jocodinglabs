# Dockerfile.claude
# Docker sandbox for Claude Code --dangerously-skip-permissions
# Project: JoCoding Labs (Next.js 15 + Turso + Claude API)

FROM node:20

# Claude Code + project toolchain
RUN npm install -g @anthropic-ai/claude-code pnpm typescript

# Non-root user (required for --dangerously-skip-permissions)
RUN useradd -m -s /bin/bash claude && \
    mkdir -p /workspace/node_modules && chown -R claude:claude /workspace

# Allow claude to fix volume permissions on startup
RUN apt-get update -qq && apt-get install -y -qq sudo > /dev/null && \
    echo "claude ALL=(ALL) NOPASSWD: /bin/chown" >> /etc/sudoers.d/claude && \
    rm -rf /var/lib/apt/lists/*

# Entrypoint: fix node_modules permissions then run CMD
RUN echo '#!/bin/bash\nif [ ! -w /workspace/node_modules ]; then\n  sudo chown -R claude:claude /workspace/node_modules 2>/dev/null || true\nfi\nexec "$@"' > /home/claude/entrypoint.sh && \
    chmod +x /home/claude/entrypoint.sh && \
    chown claude:claude /home/claude/entrypoint.sh

# git config
USER claude
RUN git config --global user.name "Docker Claude" && \
    git config --global user.email "claude@docker.local"

WORKDIR /workspace

ENTRYPOINT ["/home/claude/entrypoint.sh"]
CMD ["bash"]
